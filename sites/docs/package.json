	},
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --config ../../.prettierrc --write .",
		"lint": "prettier --config ../../.prettierrc --check .",
		"test": "echo 'No tests configured for docs site'",
		"test:unit": "echo 'No unit tests configured for docs site'",
		"test:coverage": "echo 'No test coverage configured for docs site'",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"devDependencies": {
		"@lucide/svelte": "^0.488.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4",
		"mode-watcher": "1.0.2",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"svelte-docsmith": "workspace:*",
		"tailwindcss": "^4",
		"typescript": "^5.0.0",
		"vite": "^8.1.3"
	}
}
