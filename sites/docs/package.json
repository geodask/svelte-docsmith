	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "velite && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "velite && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "velite && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --config ../../.prettierrc --write .",
		"lint": "prettier --config ../../.prettierrc --check .",
		"test": "echo 'No tests configured for docs site'",
		"test:unit": "echo 'No unit tests configured for docs site'",
		"test:coverage": "echo 'No test coverage configured for docs site'",
		"typecheck": "velite && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"velite": "velite"
	},
	"devDependencies": {
		"@hbsnow/rehype-sectionize": "^1.0.7",
		"@lucide/svelte": "^0.488.0",
		"@shikijs/rehype": "^3",
		"@shikijs/transformers": "^3.3.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5",
		"@tailwindcss/vite": "^4",
		"bits-ui": "^1.3.19",
		"clsx": "^2.1.1",
		"mdsvex": "^0.12.3",
		"mode-watcher": "1.0.2",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"shiki": "^3.2.2",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"svelte-docsmith": "workspace:*",
		"tailwindcss": "^4",
		"tw-animate-css": "^1",
		"typescript": "^5.0.0",
		"unified": "^11.0.5",
		"velite": "^0.2.2",
		"vite": "^8.1.3"
	}
}
