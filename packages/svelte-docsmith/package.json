{
	"name": "svelte-docsmith",
	"version": "0.8.0",
	"description": "A framework for building beautiful documentation sites with Svelte.",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --config ../../.prettierrc --write .",
		"lint": "prettier --config ../../.prettierrc --check . && eslint .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:unit": "vitest run",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"author": {
		"name": "George Daskalakis",
		"email": "george.dask97@gmail.com",
		"url": "https://github.com/geodask"
	},
	"main": "dist/index.js",
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": false,
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./preprocess": {
			"types": "./dist/buildtime/preprocess.d.ts",
			"default": "./dist/buildtime/preprocess.js"
		},
		"./vite": {
			"types": "./dist/buildtime/vite/index.d.ts",
			"default": "./dist/buildtime/vite/index.js"
		},
		"./content": {
			"types": "./dist/fallbacks/content.d.ts",
			"default": "./dist/fallbacks/content.js"
		},
		"./search": {
			"types": "./dist/fallbacks/search.d.ts",
			"default": "./dist/fallbacks/search.js"
		},
		"./llms": {
			"types": "./dist/fallbacks/llms.d.ts",
			"default": "./dist/fallbacks/llms.js"
		},
		"./changelog": {
			"types": "./dist/fallbacks/changelog.d.ts",
			"default": "./dist/fallbacks/changelog.js"
		},
		"./mermaid": {
			"types": "./dist/components/docs/mermaid.svelte.d.ts",
			"svelte": "./dist/components/docs/mermaid.svelte",
			"default": "./dist/components/docs/mermaid.svelte"
		},
		"./theme.css": "./dist/theme.css",
		"./themes/*.css": "./dist/themes/*.css",
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/geodask/svelte-docsmith.git"
	},
	"license": "MIT",
	"peerDependencies": {
		"@sveltejs/kit": "^2.16.0",
		"mermaid": "^10.0.0 || ^11.0.0",
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"mermaid": {
			"optional": true
		}
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.2",
		"@shikijs/twoslash": "3.23.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.4",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22",
		"@vitest/coverage-v8": "4.1.9",
		"jsdom": "^26.0.0",
		"mermaid": "^11.16.0",
		"publint": "^0.3.2",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"twoslash-svelte": "0.3.9",
		"typescript": "^5.8.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@hbsnow/rehype-sectionize": "^1.0.7",
		"@lucide/svelte": "^1.24.0",
		"@shikijs/transformers": "^3.3.0",
		"@tailwindcss/typography": "^0.5.16",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"esm-env": "^1.2.2",
		"flexsearch": "^0.8.212",
		"github-slugger": "^2.0.0",
		"js-yaml": "^4.1.0",
		"marked": "^18.0.6",
		"mdsvex": "^0.12.3",
		"mode-watcher": "^1.0.2",
		"rehype-slug": "^6.0.0",
		"shiki": "^3.2.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"svelte5",
		"docs",
		"documentation",
		"documentation-generator",
		"docs-site",
		"markdown",
		"mdsvex",
		"shiki",
		"ui",
		"components"
	]
}
